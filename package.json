    "@vitest/coverage-v8": "^3.2.7",
    "happy-dom": "^16.8.1",
    "playwright-ctrf-json-reporter": "^0.0.29",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.2.7",
    "vitest-ctrf-json-reporter": "^0.0.3"
  }
